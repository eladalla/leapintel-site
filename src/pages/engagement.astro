---
---

<!doctype html>
<html lang="en">
  <head>
    <!-- META / SEO -->
    <meta charset="UTF-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Leapintel Solutions</title>
    <meta
      name="description"
      content="Selected sections of the Leapintel Solutions website are currently being finalized. For interim CIO, fractional executive leadership, or strategic advisory inquiries, contact info@leapintel.com."
    />
    <meta property="og:title" content="Leapintel Solutions" />
    <meta
      property="og:description"
      content="Strategic Technology Leadership for Organizations in Transition."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://leapintel.com" />
    <meta property="og:image" content="https://leapintel.com/leapintel-logo.png" />

    <style>  
      /* =================================
         ROOT VARIABLES
         ================================= */
      :root {
        --blue: #1c2faa;
        --light-blue: #6fa8dc;
        --gold: #f4b000;
        --orange: #f28c18;
        --text: #1f2937;
        --muted: #5b6472;
        --white: #ffffff;
        --border: rgba(255, 255, 255, 0.35);
        --shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
      }

      /* =================================
         BASE / RESET
         ================================= */
      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        min-height: 100%;
        font-family: Arial, Helvetica, sans-serif;
        color: var(--text);
      }

      body {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 20px;
        background:
          radial-gradient(circle at top left, rgba(111, 168, 220, 0.35), transparent 35%),
          radial-gradient(circle at bottom right, rgba(242, 140, 24, 0.22), transparent 30%),
          linear-gradient(135deg, #f8fbff 0%, #eef4fb 45%, #fdf8f2 100%);
      }

      /* =================================
         PAGE WRAPPER
         ================================= */
      .shell {
        width: 100%;
        max-width: 960px;
      }

      .card {
        position: relative;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid var(--border);
        border-radius: 28px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }

      .background-logo {
        position: absolute;
        top: 35px;
        left: 50%;
        width: 620px;
        max-width: none;
        opacity: 0.11;
        transform: translateX(-50%);
        pointer-events: none;
      }

      .content {
        padding: 56px 32px;
        text-align: center;
      }

      .eyebrow {
        display: inline-block;
        margin-bottom: 16px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(28, 47, 170, 0.08);
        color: var(--blue);
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0 0 16px;
        color: var(--text);
        font-size: clamp(2rem, 4vw, 3.25rem);
        line-height: 1.1;
      }

      .subhead {
        max-width: 720px;
        margin: 0 auto 18px;
        color: var(--muted);
        font-size: clamp(1.05rem, 2vw, 1.22rem);
        line-height: 1.65;
      }

      .body-copy {
        max-width: 720px;
        margin: 0 auto;
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.8;
      }

      .contact-box {
        max-width: 680px;
        margin: 32px auto 0;
        padding: 18px 20px;
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid rgba(28, 47, 170, 0.08);
        border-radius: 18px;
      }

      .contact-label {
        margin: 0 0 8px;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .contact-email {
        display: inline-block;
        color: var(--blue);
        font-size: 1.05rem;
        font-weight: 700;
        text-decoration: none;
      }

      .contact-email:hover {
        text-decoration: underline;
      }

      .brand-accent {
        width: 100%;
        height: 3px;
        margin: 100px auto 5px auto;
        background: linear-gradient(
          90deg,
          #1c2faa,
          #6fa8dc,
          #f4b000,
          #f28c18
        );
      }

      .footer-note {
        margin-top: 22px;
        color: #6b7280;
        font-size: 0.92rem;
      }

      /* =================================
         RESPONSIVE
         ================================= */
      @media (max-width: 640px) {
        .content {
          padding: 40px 20px;
        }

        .background-logo {
          width: 360px;
          opacity: 0.1;
        }

        .contact-box {
          padding: 16px;
        }
      }
    </style>
  </head>

  <body>
    <main class="shell">
      <!-- PLACEHOLDER CARD -->
      <section class="card">
        <img class="background-logo" src="/leapintel-logo.png" alt="" />

        <div class="content">
          <div class="eyebrow">Section Update</div>

          <h1>Strategic Technology Leadership for Organizations in Transition</h1>

          <p class="subhead">
            This section is currently being updated and will be available shortly.
          </p>

          
          <div class="contact-box">
            <p class="contact-label">
              For immediate inquiries or conversation:
            </p>
            <a class="contact-email" href="mailto:info@leapintel.com">
              info@leapintel.com
            </a>
          </div>

          <div class="brand-accent"></div>

          <p class="footer-note">
            © 2019–2026 Leapintel Solutions. All rights reserved.
          </p>
        </div>
      </section>
    </main>
  </body>
</html>