---
---

<!doctype html>
<html lang="en">
  <head>
    <!-- META / SEO -->
    <meta charset="UTF-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Engagement | Leapintel Solutions</title>
    <meta
      name="description"
      content="This section of the Leapintel Solutions website is currently being updated and will be available shortly. For inquiries, contact info@leapintel.com."
    />
    <meta property="og:title" content="Engagement | Leapintel Solutions" />
    <meta
      property="og:description"
      content="This section is currently being updated and will be available shortly."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://leapintel.com/capabilities" />
    <meta property="og:image" content="https://leapintel.com/leapintel-logo.png" />

    <style>
      /* =================================
         ROOT VARIABLES
         ================================= */
      :root {
        --blue: #1c2faa;
        --light-blue: #6fa8dc;
        --gold: #f4b000;
        --orange: #f28c18;
        --text: #1f2937;
        --muted: #5b6472;
        --white: #ffffff;
        --border: rgba(255, 255, 255, 0.35);
        --shadow: 0 20px 50px rgba(0, 0, 0, 0.12);
        --max-width: 960px;
      }

      /* =================================
         BASE / RESET
         ================================= */
      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        min-height: 100%;
        font-family: Arial, Helvetica, sans-serif;
        color: var(--text);
      }

      body {
        min-height: 100vh;
        padding: 22px 16px;
        background:
          radial-gradient(circle at top left, rgba(111, 168, 220, 0.35), transparent 35%),
          radial-gradient(circle at bottom right, rgba(242, 140, 24, 0.22), transparent 30%),
          linear-gradient(135deg, #f8fbff 0%, #eef4fb 45%, #fdf8f2 100%);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      /* =================================
         PAGE WRAPPER
         ================================= */
      .shell {
        width: 100%;
        max-width: var(--max-width);
        margin: 0 auto;
      }

      .card {
        position: relative;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid var(--border);
        border-radius: 28px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
      }

      /* =================================
         HEADER / NAVIGATION
         ================================= */
      .site-header {
        position: relative;
        z-index: 20;
        width: 100%;
        background: rgba(219, 227, 236, 0.72);
        border-bottom: 1px solid rgba(23, 33, 50, 0.08);
      }

      .nav-shell {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 22px 24px;
      }

      .nav-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        position: relative;
      }

      .brand {
        white-space: nowrap;
        color: #172132;
        font-size: 1.18rem;
        font-weight: 600;
        letter-spacing: 0.01em;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 32px;
        color: #4b5563;
        font-size: 0.92rem;
        font-weight: 500;
      }

      .nav-links a {
        transition: color 0.2s ease, opacity 0.2s ease;
      }

      .nav-links a:hover {
        color: #172132;
        opacity: 1;
      }

      .nav-toggle {
        display: none;
        width: 44px;
        height: 44px;
        padding: 0;
        border: none;
        background: transparent;
        cursor: pointer;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 5px;
      }

      .nav-toggle span {
        display: block;
        width: 22px;
        height: 2px;
        background: #172132;
        border-radius: 999px;
        transition: transform 0.2s ease, opacity 0.2s ease;
      }

      /* =================================
         PLACEHOLDER CONTENT
         ================================= */
      .background-logo {
        position: absolute;
        top: 82px;
        left: 50%;
        width: 620px;
        max-width: none;
        opacity: 0.08;
        transform: translateX(-50%);
        pointer-events: none;
      }

      .content {
        padding: 56px 32px;
        text-align: center;
      }

      .eyebrow {
        display: inline-block;
        margin-bottom: 16px;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(28, 47, 170, 0.08);
        color: var(--blue);
        font-size: 0.88rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0 0 16px;
        color: var(--text);
        font-size: clamp(2rem, 4vw, 3.25rem);
        line-height: 1.1;
      }

      .subhead {
        max-width: 720px;
        margin: 0 auto 18px;
        color: var(--muted);
        font-size: clamp(1.05rem, 2vw, 1.22rem);
        line-height: 1.65;
      }

      .contact-box {
        max-width: 680px;
        margin: 32px auto 0;
        padding: 18px 20px;
        background: rgba(255, 255, 255, 0.82);
        border: 1px solid rgba(28, 47, 170, 0.08);
        border-radius: 18px;
      }

      .contact-label {
        margin: 0 0 8px;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .contact-email {
        display: inline-block;
        color: var(--blue);
        font-size: 1.05rem;
        font-weight: 700;
      }

      .contact-email:hover {
        text-decoration: underline;
      }

      .brand-accent {
        width: 100%;
        height: 3px;
        margin: 100px auto 5px auto;
        background: linear-gradient(
          90deg,
          #1c2faa,
          #6fa8dc,
          #f4b000,
          #f28c18
        );
      }

      .footer-note {
        margin-top: 22px;
        color: #6b7280;
        font-size: 0.92rem;
      }

      /* =================================
         RESPONSIVE
         ================================= */
      @media (max-width: 720px) {
        body {
          padding: 16px 12px;
        }

        .nav-shell {
          padding: 18px 18px;
        }

        .nav-bar {
          gap: 16px;
        }

        .brand {
          font-size: 1.05rem;
        }

        .nav-toggle {
          display: inline-flex;
        }

        .nav-links {
          display: none;
          position: absolute;
          top: calc(100% + 12px);
          left: 0;
          right: 0;
          z-index: 30;
          flex-direction: column;
          align-items: flex-start;
          gap: 0;
          padding: 10px 0;
          background: rgba(255, 255, 255, 0.98);
          border: 1px solid rgba(23, 33, 50, 0.08);
          border-radius: 14px;
          box-shadow: 0 12px 30px rgba(23, 33, 50, 0.08);
        }

        .nav-links.is-open {
          display: flex;
        }

        .nav-links a {
          width: 100%;
          padding: 12px 16px;
          font-size: 0.92rem;
          line-height: 1.3;
        }

        .nav-links a:hover {
          background: rgba(219, 227, 236, 0.45);
        }

        .content {
          padding: 40px 20px;
        }

        .background-logo {
          top: 110px;
          width: 360px;
          opacity: 0.08;
        }

        .contact-box {
          padding: 16px;
        }
      }

      @media (max-width: 520px) {
        .brand {
          font-size: 1.02rem;
        }
      }
    </style>
  </head>

  <body>
    <main class="shell">
      <section class="card">
        <!-- SITE HEADER -->
        <header class="site-header">
          <div class="nav-shell">
            <div class="nav-bar">
              <a class="brand" href="/">Leapintel Solutions</a>

              <button
                class="nav-toggle"
                type="button"
                aria-expanded="false"
                aria-controls="primary-navigation"
                aria-label="Open navigation"
              >
                <span></span>
                <span></span>
                <span></span>
              </button>

              <nav class="nav-links" id="primary-navigation" aria-label="Primary">
                <a href="/about">About</a>
                <a href="/engagement">Engagement Models</a>
                <a href="/capabilities">Capabilities</a>
                <a href="/experience">Experience</a>
                <a href="/contact">Contact</a>
              </nav>
            </div>
          </div>
        </header>

        <!-- PLACEHOLDER CONTENT -->
        <img class="background-logo" src="/leapintel-logo.png" alt="" />

        <div class="content">
          <div class="eyebrow">Section Update</div>

          <h1>Strategic Technology Leadership for Organizations in Transition</h1>

          <p class="subhead">
            This section is currently being updated and will be available shortly.
          </p>

          <div class="contact-box">
            <p class="contact-label">For immediate inquiries or conversation:</p>
            <a class="contact-email" href="mailto:info@leapintel.com">
              info@leapintel.com
            </a>
          </div>

          <div class="brand-accent"></div>

          <p class="footer-note">
            © 2019–2026 Leapintel Solutions. All rights reserved.
          </p>
        </div>
      </section>
    </main>

    <script>
      const navToggle = document.querySelector('.nav-toggle');
      const navLinks = document.querySelector('.nav-links');

      if (navToggle && navLinks) {
        navToggle.addEventListener('click', () => {
          const isOpen = navLinks.classList.toggle('is-open');
          navToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });
      }
    </script>
  </body>
</html>