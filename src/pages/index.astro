---
---

<!doctype html>
<html lang="en">
  <head>
    <!-- META / SEO -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Leapintel Solutions</title>
    <meta
      name="description"
      content="This section of the Leapintel Solutions website is currently being updated and will be available shortly. For inquiries, contact info@leapintel.com."
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <meta property="og:title" content="Leapintel Solutions" />
    <meta
      property="og:description"
      content="This section is currently being updated and will be available shortly."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://leapintel.com" />
    <meta property="og:image" content="https://leapintel.com/chicago-skyline.jpg" />

    <style>
       /* =================================
          ROOT VARIABLES
          ================================= */
      :root {
        --navy: #142033;
        --blue: #1c2faa;
        --light-blue: #6fa8dc;
        --gold: #f4b000;
        --orange: #f28c18;
        --white: #ffffff;
        --text-light: rgba(255, 255, 255, 0.9);
        --text-muted: rgba(255, 255, 255, 0.78);
        --shadow: 0 20px 50px rgba(0, 0, 0, 0.18);
        --max-width: 1200px;
        --header-left: 42px;
        --hero-left: 32px;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: #ffffff;
        color: #1f2937;
      }

      /* =================================
        SHARED SECTION STYLES
        ================================= */

      .section-container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 24px;
      }

      h2 {
        font-size: clamp(2rem, 3vw, 2.6rem);
        font-weight: 500;
        margin: 0 0 22px;
        letter-spacing: -0.02em;
        color: #172132;
      }

      .section-intro {
        max-width: 52ch;
        font-size: 1.05rem;
        line-height: 1.7;
        margin-bottom: 44px;
        color: #4b5563;
      }

      /* =================================
          BASE / RESET
          ================================= */

      body {
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      /* =================================
          HEADER / NAVIGATION
          ================================= */

      .site-header {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 20;
      }

      .nav-shell {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 24px var(--header-left) 0;
      }

      .nav-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .brand {
        color: white;
        font-size: 1.18rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        text-decoration: none;
        white-space: nowrap;
      }

      .nav-links {
        display: flex;
        gap: 32px;
        align-items: center;
        color: rgba(255, 255, 255, 0.9);
        font-size: 0.92rem;
        font-weight: 500;
      }

      .nav-links a {
        transition: opacity 0.2s ease;
      }

      .nav-links a:hover {
        opacity: 0.8;
      }

      .nav-bar {
        position: relative;
      }

      .nav-toggle {
        display: none;
        width: 44px;
        height: 44px;
        padding: 0;
        border: none;
        background: transparent;
        cursor: pointer;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 5px;
      }

      .nav-toggle span {
        display: block;
        width: 22px;
        height: 2px;
        background: #ffffff;
        border-radius: 999px;
        transition: transform 0.2s ease, opacity 0.2s ease;
      }

      /* =================================
        HERO SECTION
        ================================= */

      .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        overflow: hidden;
        background:
          linear-gradient(
            90deg,
            rgba(10, 20, 35, 0.78) 0%,
            rgba(10, 20, 35, 0.68) 34%,
            rgba(10, 20, 35, 0.38) 58%,
            rgba(10, 20, 35, 0.18) 100%
          ),
          url('/chicago-skyline.jpg') center center / cover no-repeat;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(
            180deg,
            rgba(10, 20, 35, 0.08) 0%,
            rgba(10, 20, 35, 0.16) 100%
          );
        pointer-events: none;
      }

      .hero-content {
        position: relative;
        z-index: 5;
        width: 100%;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 140px var(--hero-left) 96px;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
        gap: 56px;
        align-items: start;
        min-height: calc(100vh - 220px);
      }

      .hero-left {
        max-width: 700px;
      }

      .hero-right {
        max-width: 440px;
        margin-top: 42px;
      }

      h1 {
        margin: 0;
        color: var(--white);
        font-size: clamp(2.75rem, 5vw, 5rem);
        font-weight: 500;
        line-height: 1.07;
        letter-spacing: -0.03em;
        max-width: 11.5ch;
      }

      .hero-copy {
        margin: 0 0 30px;
        max-width: 42ch;
        color: var(--text-light);
        font-size: clamp(1.02rem, 1.35vw, 1.16rem);
        line-height: 1.72;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        align-items: center;
      }

      .hero-actions a {
        min-width: 250px;
      }

      .button-primary,
      .button-secondary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        box-sizing: border-box;
        appearance: none;
        -webkit-appearance: none;
        height: 46px;
        padding: 0 20px;
        border-radius: 999px;
        font-size: 0.92rem;
        font-weight: 600;
        line-height: 1;
        text-decoration: none;
        transition:
          transform 0.2s ease,
          background 0.2s ease,
          border-color 0.2s ease,
          color 0.2s ease,
          box-shadow 0.2s ease;
      }

      .button-primary {
        background: rgba(255, 255, 255, 0.95);
        color: #172132;
        border: 1px solid rgba(255, 255, 255, 0.95);
        box-shadow: none;
      }

      .button-primary:hover {
        transform: translateY(-1px);
        background: #faf6f6;
      }

      .button-secondary {
        background: rgba(10, 20, 35, 0.34);
        color: rgba(255, 255, 255, 0.98);
        border: 1px solid rgba(255, 255, 255, 0.34);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        box-shadow: none;
      }

      .button-secondary:hover {
        background: rgba(10, 20, 35, 0.44);
        border-color: rgba(255, 255, 255, 0.42);
      }

      .scroll-cue {
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        bottom: 28px;
        z-index: 6;
        color: rgba(255, 255, 255, 0.76);
        font-size: 0.85rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        white-space: nowrap;
        text-align: center;
      }

      /* =================================
          LEADERSHIP & EXPERIENCE
          ================================= */
      .leadership {
        padding: 85px 0 90px;
        background: #ffffff;
      }
      
      .leadership-grid {
        margin-top: 40px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 36px;
      }

      .leadership-card h3 {
        font-size: 1.05rem;
        font-weight: 600;
        margin-bottom: 10px;
      }

      .leadership-card p {
        font-size: 0.95rem;
        line-height: 1.65;
        color: #4b5563;
      }

      .leadership-card {
        background: #fbfbfc;
        border: 1px solid rgba(23, 33, 50, 0.05);
        padding: 24px 22px;
        border-radius: 14px;
        box-shadow: 0 4px 14px rgba(23, 33, 50, 0.025);
      }

      /* =================================
        ENGAGEMENT MODEL
        ================================= */

      .engagement {
        padding: 95px 0 100px;
        background: #f3f5f8;
      }
            
      .engagement-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
      }

      .engagement-card {
        background: #ffffff;
        border: 1px solid rgba(23, 33, 50, 0.08);
        padding: 30px 26px;
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(23, 33, 50, 0.04);
      }

      .engagement-card h3 {
        margin: 0 0 12px;
        font-size: 1.08rem;
        font-weight: 600;
        color: #172132;
      }

      .engagement-card p {
        margin: 0;
        font-size: 0.96rem;
        line-height: 1.7;
        color: #4b5563;
      }

      /* =================================
        STRATEGIC CAPABILITIES
        ================================= */

      .capabilities {
        padding: 90px 0 95px;
        background: #ffffff;
      }
            
      .capabilities-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 34px 60px;
      }

      .capability h3 {
        margin: 0 0 10px;
        font-size: 1.05rem;
        font-weight: 600;
        color: #172132;
      }

      .capability p {
        margin: 0;
        font-size: 0.96rem;
        line-height: 1.7;
        color: #4b5563;
      }

      /* =================================
        CTA SECTION
        ================================= */

      .cta {
        padding: 100px 0 110px;
        background: #142033;
        text-align: center;
      }

      .cta h2 {
        color: #ffffff;
        margin: 0 0 20px;
      }

      .cta .section-intro {
        max-width: 56ch;
        margin: 0 auto 36px;
        color: rgba(255, 255, 255, 0.82);
      }

      .cta-actions {
        display: flex;
        justify-content: center;
        gap: 18px;
        flex-wrap: wrap;
      }

      /* =================================
        FOOTER (LIGHT VERSION)
        ================================= */

      .site-footer {
        background: #ffffff;
        color: #1f2937;
        padding: 60px 24px 30px;
        border-top: 1px solid rgba(23, 33, 50, 0.08);
      }

      .footer-container {
        align-items: flex-start;
        max-width: var(--max-width);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr;
        gap: 28px;
      }

      .footer-logo {
        width: 130px;
        margin-bottom: 12px;
      }

      .footer-left {
        display: flex;
        align-items: center;
        margin-top: 4px;
        flex-direction: column;
        gap: 10px;
      }

      .footer-tagline {
        font-size: 0.85rem;
        line-height: 1.5;
        margin-top: 6px;
        max-width: 220px;
        color: #374151;
      }

      .footer-links {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .footer-links a {
        font-size: 0.9rem;
        line-height: 1.4;
        color: #374151;
      }

      .footer-links a:hover {
        color: #111827;
      }

      .footer-contact p {
        margin: 0 0 8px;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #6b7280;
      }

      .footer-contact a {
        font-size: 0.9rem;
        color: #374151;
      }

      .footer-bottom {
        margin-top: 40px;
        text-align: center;
        font-size: 0.8rem;
        color: #6b7280;
      }

      
      /* =================================
          RESPONSIVE BREAKPOINTS
          ================================= */
      
      @media (max-width: 900px) {
        .nav-links {
          gap: 18px;
          font-size: 0.9rem;
        }

        .hero-grid {
          grid-template-columns: 1fr;
          gap: 28px;
          min-height: auto;
        }

        .hero-left {
          max-width: 100%;
        }

        .hero-right {
          max-width: 640px;
          margin-top: 0;
        }

        h1 {
          max-width: 11ch;
        }

        .leadership-grid {
          grid-template-columns: 1fr;
        }

        .engagement-grid {
          grid-template-columns: 1fr;
        }

        .capabilities-grid {
          grid-template-columns: 1fr;
        }

        .footer-container {
          grid-template-columns: 1fr;
          gap: 30px;
        }

      }

      @media (max-width: 720px) {
        .nav-bar {
          gap: 16px;
        }

        .nav-toggle {
          display: inline-flex;
        }

        .nav-links {
          display: none;
          position: absolute;
          top: calc(100% + 12px);
          left: 0;
          right: 0;
          z-index: 30;
          flex-direction: column;
          align-items: flex-start;
          gap: 0;
          padding: 10px 0;
          background: rgba(10, 20, 35, 0.94);
          border: 1px solid rgba(255, 255, 255, 0.14);
          border-radius: 14px;
          box-shadow: 0 12px 30px rgba(0, 0, 0, 0.18);
          backdrop-filter: blur(10px);
          -webkit-backdrop-filter: blur(10px);
        }

        .nav-links.is-open {
          display: flex;
        }

        .nav-links a {
          width: 100%;
          padding: 12px 16px;
          font-size: 0.92rem;
          line-height: 1.3;
        }

        .nav-links a:hover {
          background: rgba(255, 255, 255, 0.06);
        }

        .hero {
          min-height: 100svh;
          background-position: 62% center;
        }

        .hero-content {
          padding: 170px 20px 70px;
        }

        .hero-grid {
          gap: 24px;
        }

        h1 {
          font-size: clamp(2.4rem, 9vw, 3.4rem);
          line-height: 1.02;
        }

        .hero-copy {
          font-size: 1rem;
          line-height: 1.65;
          max-width: 36ch;
        }

        .hero-actions {
          flex-direction: column;
          align-items: stretch;
        }

        .button-primary,
        .button-secondary {
          width: 100%;
          min-height: 46px;
          font-size: 0.9rem;
        }

        .scroll-cue {
          left: 50%;
          transform: translateX(-50%);
          text-align: center;
          bottom: 16px;
          font-size: 0.78rem;
        }
      }

      @media (max-width: 520px) {
        .nav-shell {
          padding: 18px 18px 0;
        }

        .brand {
          font-size: 1.05rem;
        }

        .hero-content {
          padding: 156px 18px 70px;
        }
      }
    </style>
  </head>

  <script>
    const navToggle = document.querySelector('.nav-toggle');
    const navLinks = document.querySelector('.nav-links');

    if (navToggle && navLinks) {
      navToggle.addEventListener('click', () => {
        const isOpen = navLinks.classList.toggle('is-open');
        navToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    }
  </script>

  <body>
    <header class="site-header">
      <div class="nav-shell">
        <div class="nav-bar">
          <a class="brand" href="/">Leapintel Solutions</a>

          <button
            class="nav-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="primary-navigation"
            aria-label="Open navigation"
          >
            <span></span>
            <span></span>
            <span></span>
          </button>

          <nav class="nav-links" id="primary-navigation" aria-label="Primary">
            <a href="/about">About</a>
            <a href="/engagement">Engagement Models</a>
            <a href="/focus-areas">Focus Areas</a>
            <a href="/selected-work">Selected Work</a>
            <a href="/contact">Contact</a>
          </nav>
        </div>
      </div>
    </header>

    <main>
      <!-- HERO SECTION -->
      <section class="hero">
        <div class="hero-content">
          <div class="hero-grid">
            <div class="hero-left">
              <h1>Strategic Technology Leadership for Organizations in Transition</h1>
            </div>

            <div class="hero-right">
              <p class="hero-copy">
                Leapintel Solutions provides interim CIO leadership, fractional executive
                engagement, and strategic advisory support for organizations navigating
                complex technology, operational, and transformation challenges.
              </p>

              <div class="hero-actions">
                <a class="button-primary" href="/contact">Start a Conversation</a>
                <a class="button-secondary" href="/engagement">
                  Learn About Our Engagement Model
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="scroll-cue">Scroll to explore</div>
      </section>

      <!-- Leadership & Experience SECTION -->
      <section class="leadership">
        <div class="section-container">

          <h2>Leadership & Experience</h2>

          <p class="section-intro">
            Decades of enterprise technology leadership across government,
            healthcare, aviation, and global consulting environments.
            Leapintel Solutions brings executive-level perspective to
            organizations navigating transformation, complex technology
            ecosystems, and operational change.
          </p>

          <div class="leadership-grid">

            <div class="leadership-card">
              <h3>Enterprise Leadership</h3>
              <p>
                Executive leadership of large-scale technology organizations,
                overseeing enterprise platforms, modernization initiatives,
                and operational delivery across complex environments.
              </p>
            </div>

            <div class="leadership-card">
              <h3>Transformation Experience</h3>
              <p>
                Proven experience guiding organizations through modernization,
                digital transformation, operating model change, and critical
                technology decisions.
              </p>
            </div>

            <div class="leadership-card">
              <h3>Cross-Sector Perspective</h3>
              <p>
                Leadership roles across government, healthcare, aviation,
                and global consulting bring a broad perspective to complex
                organizational and technology challenges.
              </p>
            </div>

          </div>

        </div>
      </section>

      <!-- ENGAGEMENT MODEL -->
      <section class="engagement">
        <div class="section-container">
          <h2>Engagement Model</h2>

          <p class="section-intro">
            Leapintel Solutions provides flexible executive engagement models tailored to
            organizational transition, modernization priorities, leadership gaps, and
            complex technology decision-making.
          </p>

          <div class="engagement-grid">
            <div class="engagement-card">
              <h3>Interim CIO</h3>
              <p>
                Short-term executive leadership for organizations navigating
                transition, leadership vacancies, critical initiatives, or periods
                requiring immediate strategic and operational direction.
              </p>
            </div>

            <div class="engagement-card">
              <h3>Fractional Executive Leadership</h3>
              <p>
                Part-time executive technology leadership for organizations that need
                senior guidance, governance, and transformation support without a
                full-time CIO structure.
              </p>
            </div>

            <div class="engagement-card">
              <h3>Executive Advisory</h3>
              <p>
                Strategic advisory support for executive teams, boards, and
                organizational leaders facing complex technology decisions,
                modernization efforts, or operating model challenges.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- STRATEGIC CAPABILITIES -->

      <section class="capabilities">
        <div class="section-container">
          
          <h2>Strategic Capabilities</h2>

          <p class="section-intro">
            Executive leadership across the core domains required to modernize
            technology organizations, strengthen operations, and enable long-term
            business and mission outcomes.
          </p>

          <div class="capabilities-grid">
            <div class="capability">
              <h3>Technology Strategy & Governance</h3>
              <p>
                Define and align enterprise technology strategy with organizational
                priorities, establish governance models, and guide long-term
                investment decisions.
              </p>
            </div>

            <div class="capability">
              <h3>Digital Transformation & Modernization</h3>
              <p>
                Lead modernization initiatives, legacy system transformation,
                cloud adoption, and operating model evolution across complex
                environments.
              </p>
            </div>

            <div class="capability">
              <h3>Enterprise Applications & Platforms</h3>
              <p>
                Oversee enterprise application ecosystems, platform strategy,
                integration, and lifecycle management across mission-critical systems.
              </p>
            </div>

            <div class="capability">
              <h3>Infrastructure & Cloud Strategy</h3>
              <p>
                Guide infrastructure modernization, cloud migration, and hybrid
                architecture decisions to improve scalability, resilience, and cost
                efficiency.
              </p>
            </div>

            <div class="capability">
              <h3>Cybersecurity & Risk Management</h3>
              <p>
                Strengthen security posture, risk management frameworks, and
                compliance alignment across enterprise environments.
              </p>
            </div>

            <div class="capability">
              <h3>IT Operations & Service Delivery</h3>
              <p>
                Improve service delivery models, ITSM practices, and operational
                performance to enhance user experience and organizational support.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- CONTACT / CTA -->

      <section class="cta">
        <div class="section-container">
          <h2>Start a Conversation</h2>

          <p class="section-intro">
            Organizations facing leadership transitions, modernization efforts, or
            complex technology decisions often benefit from experienced executive
            guidance. If that reflects your current situation, we can begin a
            conversation.
          </p>

          <div class="cta-actions">
            <a class="button-primary" href="mailto:info@leapintel.com">
              Contact via Email
            </a>

            <a class="button-secondary" href="/contact">
              Visit Contact Page
            </a>
          </div>
        </div>
      </section>

      <!-- FOOTER -->

      <footer class="site-footer">
        <div class="footer-container">

          <div class="footer-left">
            <img src="/logo.png" alt="Leapintel Solutions" class="footer-logo" />

          </div>

          <div class="footer-links">
            <a href="/about">About</a>
            <a href="/engagement">Engagement Models</a>
            <a href="/focus-areas">Focus Areas</a>
            <a href="/selected-work">Selected Work</a>
            <a href="/contact">Contact</a>
          </div>

          <div class="footer-contact">
            <p>Contact</p>
            <a href="mailto:info@leapintel.com">info@leapintel.com</a>
          </div>

        </div>

        <div class="footer-bottom">
            <p>© 2019–2026 Leapintel Solutions. All rights reserved.</p>
        </div>
      </footer>

    </main>
  </body>
</html>