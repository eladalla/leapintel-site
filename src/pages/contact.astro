---
---

<!doctype html>
<html lang="en">
  <head>
    <!-- META / SEO -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact | Leapintel Solutions</title>
    <meta
      name="description"
      content="Contact Leapintel Solutions regarding interim CIO leadership, fractional executive support, or strategic advisory engagements."
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="shortcut icon" href="/favicon.ico" />

    <meta property="og:title" content="Contact | Leapintel Solutions" />
    <meta
      property="og:description"
      content="Contact Leapintel Solutions for interim CIO, fractional executive, or strategic advisory inquiries."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://leapintel.com/contact" />
    <meta property="og:image" content="https://leapintel.com/chicago-skyline.jpg" />

    <style>
      /* =================================
         ROOT VARIABLES
         ================================= */
      :root {
        --navy: #142033;
        --white: #ffffff;
        --max-width: 1200px;
      }

      /* =================================
         BASE / RESET
         ================================= */
      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: #ffffff;
        color: #1f2937;
      }

      body {
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      /* =================================
         SHARED SECTION STYLES
         ================================= */
      .section-container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 24px;
      }

      h2 {
        margin: 0 0 22px;
        color: #172132;
        font-size: clamp(2rem, 3vw, 2.6rem);
        font-weight: 500;
        letter-spacing: -0.02em;
      }

      .section-intro {
        max-width: 52ch;
        margin-bottom: 44px;
        color: #4b5563;
        font-size: 1.05rem;
        line-height: 1.7;
      }

      /* =================================
         HEADER / NAVIGATION
         ================================= */
      .site-header {
        position: relative;
        z-index: 20;
        width: 100%;
        background: #dbe3ec;
        border-bottom: 1px solid rgba(23, 33, 50, 0.08);
      }

      .nav-shell {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 22px 24px;
      }

      .nav-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .brand {
        white-space: nowrap;
        color: #172132;
        font-size: 1.18rem;
        font-weight: 600;
        letter-spacing: 0.01em;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 32px;
        color: #4b5563;
        font-size: 0.92rem;
        font-weight: 500;
      }

      .nav-links a {
        transition: color 0.2s ease, opacity 0.2s ease;
      }

      .nav-links a:hover {
        color: #172132;
        opacity: 1;
      }

      /* =================================
         CONTACT PAGE HEADER
         ================================= */
      .contact-header {
        padding: 80px 0;
        background: linear-gradient(180deg, #eef2f7 0%, #f7f9fc 100%);
        border-bottom: 1px solid rgba(23, 33, 50, 0.06);
      }

      .contact-header-inner {
        max-width: 860px;
      }

      .contact-eyebrow {
        margin: 0 0 14px;
        color: #5b6777;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .contact-title {
        margin: 0 0 22px;
        color: #172132;
        font-size: clamp(2.4rem, 4vw, 3.8rem);
        font-weight: 500;
        line-height: 1.08;
        letter-spacing: -0.03em;
        max-width: 14ch;
        transform: translateX(-2px);
      }

      .contact-lead {
        max-width: 58ch;
        margin: 0;
        color: #4b5563;
        font-size: 1.18rem;
        line-height: 1.72;
      }

      /* =================================
         CONTACT DETAILS
         ================================= */
      .contact-main {
        padding: 90px 0 100px;
        background: #ffffff;
      }

      .contact-card {
        max-width: 760px;
        padding: 36px 32px;
        background: #fbfbfc;
        border: 1px solid rgba(23, 33, 50, 0.06);
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(23, 33, 50, 0.035);
      }

      .contact-label {
        margin: 0 0 10px;
        color: #6b7280;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .contact-copy {
        margin: 0 0 20px;
        color: #4b5563;
        font-size: 1rem;
        line-height: 1.8;
      }

      .contact-email {
        display: inline-block;
        margin: 0 0 24px;
        color: #1c2faa;
        font-size: clamp(1.4rem, 2.2vw, 1.8rem);
        font-weight: 600;
        letter-spacing: -0.01em;
      }

      .contact-email:hover {
        text-decoration: underline;
      }

      .contact-note {
        margin: 0;
        color: #4b5563;
        font-size: 0.98rem;
        line-height: 1.75;
      }

      /* =================================
         FOOTER
         ================================= */
      .site-footer {
        padding: 60px 24px 30px;
        color: #1f2937;
        background: #ffffff;
        border-top: 1px solid rgba(23, 33, 50, 0.08);
      }

      .footer-container {
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr;
        align-items: flex-start;
        gap: 28px;
        max-width: var(--max-width);
        margin: 0 auto;
      }

      .footer-left {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        margin-top: 4px;
      }

      .footer-logo {
        width: 130px;
        margin-bottom: 12px;
      }

      .footer-links {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .footer-links a {
        color: #374151;
        font-size: 0.9rem;
        line-height: 1.4;
      }

      .footer-links a:hover {
        color: #111827;
      }

      .footer-contact p {
        margin: 0 0 8px;
        color: #6b7280;
        font-size: 0.75rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .footer-contact a {
        color: #374151;
        font-size: 0.9rem;
      }

      .footer-bottom {
        margin-top: 40px;
        color: #6b7280;
        font-size: 0.8rem;
        text-align: center;
      }

      /* =================================
         RESPONSIVE BREAKPOINTS
         ================================= */
      @media (max-width: 900px) {
        .nav-links {
          gap: 18px;
          font-size: 0.9rem;
        }

        .footer-container {
          grid-template-columns: 1fr;
          gap: 30px;
        }

        .contact-header {
          padding: 140px 0 70px;
        }

        .contact-title {
          max-width: 16ch;
        }
      }

      @media (max-width: 720px) {
        .nav-bar {
          flex-direction: column;
          align-items: flex-start;
          gap: 14px;
        }

        .nav-links {
          flex-wrap: wrap;
          gap: 12px 16px;
          font-size: 0.78rem;
          line-height: 1.2;
        }

        .contact-header {
          padding: 72px 0 56px;
        }

        .contact-title {
          margin: 0 0 18px;
          font-size: clamp(2.2rem, 8vw, 3.2rem);
          line-height: 1.05;
          max-width: 100%;
        }

        .contact-lead {
          font-size: 1.05rem;
          line-height: 1.65;
        }

        .contact-main {
          padding: 72px 0 76px;
        }

        .contact-card {
          padding: 28px 20px;
        }

        .contact-email {
          font-size: 1.45rem;
          word-break: break-word;
        }
      }

      @media (max-width: 520px) {
        .nav-shell {
          padding: 18px;
        }

        .brand {
          font-size: 1.05rem;
        }

        .contact-header-inner {
          max-width: 100%;
        }
      }
    </style>
  </head>

  <body>
    <!-- SITE HEADER -->
    <header class="site-header">
      <div class="nav-shell">
        <div class="nav-bar">
          <a class="brand" href="/">Leapintel Solutions</a>

          <nav class="nav-links" aria-label="Primary">
            <a href="/about">About</a>
            <a href="/engagement">Engagement Models</a>
            <a href="/capabilities">Capabilities</a>
            <a href="/experience">Experience</a>
            <a href="/contact">Contact</a>
          </nav>
        </div>
      </div>
    </header>

    <main>
      <!-- CONTACT PAGE HEADER -->
      <section class="contact-header">
        <div class="section-container">
          <div class="contact-header-inner">
            <p class="contact-eyebrow">Contact</p>
            <h1 class="contact-title">Start a Conversation</h1>
            <p class="contact-lead">
              For organizations navigating leadership transition, modernization,
              or complex technology decisions, Leapintel Solutions provides
              focused executive perspective and practical guidance.
            </p>
          </div>
        </div>
      </section>

      <!-- CONTACT DETAILS -->
      <section class="contact-main">
        <div class="section-container">
          <div class="contact-card">
            <p class="contact-label">Email</p>

            <p class="contact-copy">
              For inquiries regarding interim CIO leadership, fractional executive
              support, or strategic advisory engagements:
            </p>

            <a class="contact-email" href="mailto:info@leapintel.com">
              info@leapintel.com
            </a>

            <p class="contact-note">
              Initial conversations are welcomed by email and will be handled directly.
            </p>
          </div>
        </div>
      </section>

      <!-- SITE FOOTER -->
      <footer class="site-footer">
        <div class="footer-container">
          <div class="footer-left">
            <img src="/logo.png" alt="Leapintel Solutions" class="footer-logo" />
          </div>

          <div class="footer-links">
            <a href="/about">About</a>
            <a href="/engagement">Engagement Models</a>
            <a href="/capabilities">Capabilities</a>
            <a href="/experience">Experience</a>
            <a href="/contact">Contact</a>
          </div>

          <div class="footer-contact">
            <p>Contact</p>
            <a href="mailto:info@leapintel.com">info@leapintel.com</a>
          </div>
        </div>

        <div class="footer-bottom">
          <p>© 2019–2026 Leapintel Solutions. All rights reserved.</p>
        </div>
      </footer>
    </main>
  </body>
</html>